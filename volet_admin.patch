+import { Component, OnInit } from '@angular/core';
+import { CommonModule } from '@angular/common';
+import { FormBuilder, FormGroup, ReactiveFormsModule, Validators } from '@angular/forms';
+import { Router } from '@angular/router';
+import { AccountService } from '../../core/services/account.service';
+import { BulkTransferService } from '../../core/services/bulk-transfer.service';
+import { Account } from '../../core/models/account.model';
+import { BulkTransferItemResult } from '../../core/models/bulk-transfer.model';
+
+type BulkStep = 'upload' | 'confirmation' | 'results';
+
+interface CsvPreviewRow {
+  destinationAccountNumber: string;
+  amount: string;
+  label: string;
+}
+
+@Component({
+  selector: 'app-bulk-transfer',
+  standalone: true,
+  imports: [CommonModule, ReactiveFormsModule],
+  templateUrl: './bulk-transfer.component.html',
+  styleUrl: './bulk-transfer.component.css'
+})
+export class BulkTransferComponent implements OnInit {
+
+  step: BulkStep = 'upload';
+  accounts: Account[] = [];
+  selectedAccount: Account | undefined;
+
+  uploadForm: FormGroup;
+  otpForm: FormGroup;
+
+  selectedFile: File | null = null;
+  previewRows: CsvPreviewRow[] = [];
+  previewError: string | null = null;
+
+  bulkTransferId: number | null = null;
+  totalItems = 0;
+
+  results: BulkTransferItemResult[] = [];
+  successCount = 0;
+  failedCount = 0;
+
+  loading = false;
+  errorMessage: string | null = null;
+
+  constructor(
+    private fb: FormBuilder,
+    private accountService: AccountService,
+    private bulkTransferService: BulkTransferService,
+    private router: Router
+  ) {
+    this.uploadForm = this.fb.group({
+      sourceAccountId: ['', Validators.required]
+    });
+
+    this.otpForm = this.fb.group({
+      otpCode: ['', [Validators.required, Validators.minLength(6), Validators.maxLength(6)]]
+    });
+  }
+
+  ngOnInit(): void {
+    this.accountService.getMyAccounts().subscribe({
+      next: (accounts) => {
+        this.accounts = accounts;
+        if (accounts.length > 0) {
+          this.uploadForm.patchValue({ sourceAccountId: accounts[0].id });
+          this.selectedAccount = accounts[0];
+        }
+      }
+    });
+  }
+
+  onAccountChange(): void {
+    const id = Number(this.uploadForm.value.sourceAccountId);
+    this.selectedAccount = this.accounts.find(a => a.id === id);
+  }
+
+  onFileSelected(event: Event): void {
+    const input = event.target as HTMLInputElement;
+    const file = input.files && input.files.length > 0 ? input.files[0] : null;
+    this.selectedFile = file;
+    this.previewRows = [];
+    this.previewError = null;
+    this.errorMessage = null;
+
+    if (!file) {
+      return;
+    }
+
+    if (!file.name.toLowerCase().endsWith('.csv')) {
+      this.previewError = 'Le fichier doit être au format CSV.';
+      this.selectedFile = null;
+      return;
+    }
+
+    this.parseCsvPreview(file);
+  }
+
+  private parseCsvPreview(file: File): void {
+    const reader = new FileReader();
+    reader.onload = () => {
+      const text = String(reader.result || '');
+      const lines = text.split(/\r?\n/).map(l => l.trim()).filter(l => l.length > 0);
+
+      if (lines.length <= 1) {
+        this.previewError = 'Le fichier CSV ne contient aucune ligne de données.';
+        return;
+      }
+
+      const dataLines = lines.slice(1, 21); // preview first 20 rows max
+      const rows: CsvPreviewRow[] = [];
+
+      for (const line of dataLines) {
+        const parts = line.split(',').map(p => p.trim());
+        rows.push({
+          destinationAccountNumber: parts[0] ?? '',
+          amount: parts[1] ?? '',
+          label: parts[2] ?? ''
+        });
+      }
+
+      this.previewRows = rows;
+    };
+    reader.onerror = () => {
+      this.previewError = 'Impossible de lire le fichier sélectionné.';
+    };
+    reader.readAsText(file, 'UTF-8');
+  }
+
+  downloadTemplate(): void {
+    const csvContent = 'destinationAccountNumber,amount,label\n07807XXXXXXXXXXXXXXX,100.000,Loyer\n07807YYYYYYYYYYYYYYY,50.500,Fournisseur\n';
+    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
+    const url = URL.createObjectURL(blob);
+    const link = document.createElement('a');
+    link.href = url;
+    link.download = 'modele_virements_groupes.csv';
+    link.click();
+    URL.revokeObjectURL(url);
+  }
+
+  submitUpload(): void {
+    if (this.uploadForm.invalid || !this.selectedFile) {
+      this.uploadForm.markAllAsTouched();
+      if (!this.selectedFile) {
+        this.previewError = 'Veuillez sélectionner un fichier CSV.';
+      }
+      return;
+    }
+
+    this.loading = true;
+    this.errorMessage = null;
+
+    const sourceAccountId = Number(this.uploadForm.value.sourceAccountId);
+
+    this.bulkTransferService.initiateBulkTransfer(sourceAccountId, this.selectedFile).subscribe({
+      next: (response) => {
+        this.loading = false;
+        this.bulkTransferId = response.bulkTransferId;
+        this.totalItems = response.totalItems;
+        this.step = 'confirmation';
+      },
+      error: (err) => {
+        this.loading = false;
+        this.errorMessage = err.error?.message || 'Une erreur est survenue lors de l\'import du fichier.';
+      }
+    });
+  }
+
+  submitConfirmation(): void {
+    const rawOtp = this.otpForm.value.otpCode || '';
+    const cleanOtp = String(rawOtp).replace(/\D/g, '').trim();
+
+    if (cleanOtp !== rawOtp) {
+      this.otpForm.patchValue({ otpCode: cleanOtp }, { emitEvent: false });
+    }
+
+    if (this.otpForm.invalid || this.bulkTransferId === null) {
+      this.otpForm.markAllAsTouched();
+      return;
+    }
+
+    this.loading = true;
+    this.errorMessage = null;
+
+    this.bulkTransferService.confirmBulkTransfer({
+      bulkTransferId: this.bulkTransferId,
+      otpCode: cleanOtp
+    }).subscribe({
+      next: (response) => {
+        this.loading = false;
+        this.results = response.results;
+        this.successCount = response.successCount;
+        this.failedCount = response.failedCount;
+        this.step = 'results';
+      },
+      error: (err) => {
+        this.loading = false;
+        this.errorMessage = err.error?.message || 'Code incorrect, veuillez réessayer.';
+      }
+    });
+  }
+
+  backToUpload(): void {
+    this.step = 'upload';
+    this.errorMessage = null;
+  }
+
+  goToDashboard(): void {
+    this.router.navigate(['/dashboard']);
+  }
+
+  startNewBulkTransfer(): void {
+    this.step = 'upload';
+    this.selectedFile = null;
+    this.previewRows = [];
+    this.previewError = null;
+    this.errorMessage = null;
+    this.bulkTransferId = null;
+    this.totalItems = 0;
+    this.results = [];
+    this.successCount = 0;
+    this.failedCount = 0;
+    this.otpForm.reset();
+  }
+
+  get otpControl() {
+    return this.otpForm.get('otpCode');
+  }
+}
