+      REACTIVATION_UTILISATEUR: 'Réactivation',
+      MODIFICATION_ROLE: 'Changement de rôle',
+      REINITIALISATION_MOT_DE_PASSE: 'Réinitialisation mot de passe'
+    };
+    return labels[action] || action;
+  }
+}
